{
  "id": "mclaw-openai-image",
  "name": "mclaw OpenAI Image",
  "description": "Independent OpenAI-compatible image generation provider managed by mclaw.",
  "version": "0.1.3",
  "entry": "index.mjs",
  "enabledByDefault": false,
  "contracts": {
    "imageGenerationProviders": [
      "mclaw-openai-image"
    ]
